{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "input_schema": {
      "additionalProperties": true,
      "title": "Input Schema",
      "type": "object"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "output_schema": {
      "additionalProperties": true,
      "title": "Output Schema",
      "type": "object"
    },
    "permissions": {
      "items": {
        "type": "string"
      },
      "title": "Permissions",
      "type": "array"
    },
    "tool_id": {
      "minLength": 1,
      "title": "Tool Id",
      "type": "string"
    },
    "transport": {
      "title": "Transport",
      "type": "string"
    }
  },
  "required": [
    "tool_id",
    "name",
    "transport",
    "input_schema",
    "output_schema"
  ],
  "title": "ToolCapability",
  "type": "object"
}
