{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "approval_status": {
      "default": "pending",
      "title": "Approval Status",
      "type": "string"
    },
    "case_id": {
      "minLength": 1,
      "title": "Case Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "current_phase": {
      "title": "Current Phase",
      "type": "string"
    },
    "evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Evidence Ids",
      "type": "array"
    },
    "excluded_causes": {
      "items": {
        "type": "string"
      },
      "title": "Excluded Causes",
      "type": "array"
    },
    "hypothesis_ids": {
      "items": {
        "type": "string"
      },
      "title": "Hypothesis Ids",
      "type": "array"
    },
    "pending_approval_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pending Approval Id"
    },
    "regression_status": {
      "default": "pending",
      "title": "Regression Status",
      "type": "string"
    },
    "remaining_budget": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Remaining Budget"
    },
    "requirements": {
      "items": {
        "type": "string"
      },
      "title": "Requirements",
      "type": "array"
    },
    "root_cause_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Root Cause Id"
    },
    "test_cases": {
      "items": {
        "type": "string"
      },
      "title": "Test Cases",
      "type": "array"
    },
    "test_objective": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Test Objective"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "case_id",
    "current_phase"
  ],
  "title": "CaseState",
  "type": "object"
}
