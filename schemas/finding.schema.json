{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "minLength": 1,
      "title": "Case Id",
      "type": "string"
    },
    "closed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Closed At"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "finding_id": {
      "minLength": 1,
      "title": "Finding Id",
      "type": "string"
    },
    "related_evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Related Evidence Ids",
      "type": "array"
    },
    "severity": {
      "title": "Severity",
      "type": "string"
    },
    "status": {
      "default": "open",
      "title": "Status",
      "type": "string"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    }
  },
  "required": [
    "finding_id",
    "case_id",
    "summary",
    "severity"
  ],
  "title": "Finding",
  "type": "object"
}
