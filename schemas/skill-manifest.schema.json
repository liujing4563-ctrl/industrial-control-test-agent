{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_tools": {
      "items": {
        "type": "string"
      },
      "title": "Allowed Tools",
      "type": "array"
    },
    "description": {
      "title": "Description",
      "type": "string"
    },
    "inputs": {
      "items": {
        "type": "string"
      },
      "title": "Inputs",
      "type": "array"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "outputs": {
      "items": {
        "type": "string"
      },
      "title": "Outputs",
      "type": "array"
    },
    "owner": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Owner"
    },
    "skill_id": {
      "minLength": 1,
      "title": "Skill Id",
      "type": "string"
    },
    "version": {
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "skill_id",
    "name",
    "version",
    "description",
    "inputs",
    "outputs",
    "allowed_tools"
  ],
  "title": "SkillManifest",
  "type": "object"
}
