{
  "$defs": {
    "FindingSeverity": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "FindingSeverity",
      "type": "string"
    },
    "FindingStatus": {
      "enum": [
        "open",
        "confirmed",
        "resolved",
        "closed"
      ],
      "title": "FindingStatus",
      "type": "string"
    }
  },
  "$id": "urn:industrial-test-agent:schema:finding:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "minLength": 1,
      "title": "Case Id",
      "type": "string"
    },
    "closed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Closed At"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "description": {
      "title": "Description",
      "type": "string"
    },
    "evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Evidence Ids",
      "type": "array"
    },
    "finding_id": {
      "minLength": 1,
      "title": "Finding Id",
      "type": "string"
    },
    "hypothesis_ids": {
      "items": {
        "type": "string"
      },
      "title": "Hypothesis Ids",
      "type": "array"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "severity": {
      "$ref": "#/$defs/FindingSeverity"
    },
    "status": {
      "$ref": "#/$defs/FindingStatus",
      "default": "open"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "finding_id",
    "case_id",
    "title",
    "description",
    "severity"
  ],
  "title": "Finding",
  "type": "object"
}
