{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "decision": {
      "enum": [
        "allowed",
        "rejected",
        "approval_required"
      ],
      "title": "Decision",
      "type": "string"
    },
    "details": {
      "additionalProperties": true,
      "title": "Details",
      "type": "object"
    },
    "reason": {
      "title": "Reason",
      "type": "string"
    }
  },
  "required": [
    "decision",
    "reason"
  ],
  "title": "PolicyResult",
  "type": "object"
}
