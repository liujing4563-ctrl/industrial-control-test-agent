{
  "$defs": {
    "HypothesisStatus": {
      "enum": [
        "open",
        "supported",
        "contradicted",
        "confirmed",
        "rejected"
      ],
      "title": "HypothesisStatus",
      "type": "string"
    }
  },
  "$id": "urn:industrial-test-agent:schema:hypothesis:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "minLength": 1,
      "title": "Case Id",
      "type": "string"
    },
    "confidence": {
      "maximum": 1,
      "minimum": 0,
      "title": "Confidence",
      "type": "number"
    },
    "contradicting_evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Contradicting Evidence Ids",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "hypothesis_id": {
      "minLength": 1,
      "title": "Hypothesis Id",
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "statement": {
      "minLength": 1,
      "title": "Statement",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/HypothesisStatus",
      "default": "open"
    },
    "supporting_evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Supporting Evidence Ids",
      "type": "array"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "hypothesis_id",
    "case_id",
    "statement",
    "confidence"
  ],
  "title": "Hypothesis",
  "type": "object"
}
