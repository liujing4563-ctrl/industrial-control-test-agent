{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/action-intent.schema.json",
  "title": "ActionIntent",
  "type": "object",
  "properties": {
    "intentId": {"type": "string"},
    "caseId": {"type": "string"},
    "agentId": {"type": "string"},
    "actionType": {"type": "string"},
    "actionDetails": {"type": "object"},
    "reason": {"type": "string"},
    "requestedBy": {"type": "string"},
    "priority": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "status": {"type": "string", "enum": ["draft", "submitted", "approved", "rejected", "executing", "completed"]},
    "targetResource": {"type": "string"},
    "relatedEvidenceIds": {"type": "array", "items": {"type": "string"}},
    "createdAt": {"type": "string", "format": "date-time"},
    "approvedBy": {"type": "string"},
    "approvedAt": {"type": "string", "format": "date-time"}
  },
  "required": ["intentId", "caseId", "actionType", "reason", "requestedBy", "createdAt"],
  "additionalProperties": false
}
