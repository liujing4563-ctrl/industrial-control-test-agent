{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "minLength": 1,
      "title": "Case Id",
      "type": "string"
    },
    "confidence": {
      "title": "Confidence",
      "type": "number"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "title": "Created By",
      "type": "string"
    },
    "description": {
      "title": "Description",
      "type": "string"
    },
    "hypothesis_id": {
      "minLength": 1,
      "title": "Hypothesis Id",
      "type": "string"
    },
    "status": {
      "default": "open",
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "hypothesis_id",
    "case_id",
    "description",
    "confidence",
    "created_by"
  ],
  "title": "Hypothesis",
  "type": "object"
}
